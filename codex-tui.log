+#!/usr/bin/bash
+set -euo pipefail
+
+ensure_group_exists() {
+  local group_name="$1"
+  if ! getent group "${group_name}" >/dev/null 2>&1; then
+    groupadd -r "${group_name}"
+  fi
+}
+
+user_needs_group() {
+  local user_name="$1"
+  local group_name="$2"
+
+  if id -nG "${user_name}" 2>/dev/null | tr ' ' '\n' | grep -Fxq "${group_name}"; then
+    return 1
+  fi
+
+  return 0
+}
+
+ensure_group_exists audio
+ensure_group_exists realtime
+
+while IFS=: read -r user_name _ user_id _ _ home_dir shell_path; do
+  if [[ "${user_id}" -lt 1000 ]]; then
+    continue
+  fi
+
+  if [[ ! -d "${home_dir}" ]]; then
+    continue
+  fi
+
+  case "${shell_path}" in
+    ""|/sbin/nologin|/usr/sbin/nologin|/bin/false|/usr/bin/false)
+      continue
+      ;;
+  esac
+
+  missing_groups=()
+  for group_name in audio realtime; do
+    if user_needs_group "${user_name}" "${group_name}"; then
+      missing_groups+=("${group_name}")
+    fi
+  done
+
+  if ((${#missing_groups[@]} > 0)); then
+    usermod -aG "$(IFS=,; printf '%s' "${missing_groups[*]}")" "${user_name}"
+  fi
+done </etc/passwd
*** Add File: /var/home/atumia/caracal-stuff-latest/tumillanino/caracal/system_files/shared/usr/lib/systemd/system/caracal-ensure-audio-groups.service
+[Unit]
+Description=Ensure regular users are members of Caracal audio groups
+After=local-fs.target systemd-user-sessions.service
+Wants=systemd-user-sessions.service
+
+[Service]
+Type=oneshot
+ExecStart=/usr/libexec/caracal-ensure-audio-groups
+
+[Install]
+WantedBy=multi-user.target
