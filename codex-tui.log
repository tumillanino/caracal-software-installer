 copy_bundle_dir() {
   local source="$1"
   local destination_root="$2"
   local name
   name="$(basename "${source}")"
@@
   cp -a "${source}" "${destination_root}/"
 }
+
+find_bundle_dirs() {
+  local root="$1"
+  local suffix="$2"
+
+  find "${root}" \
+    -type d \
+    -name "*.${suffix}" \
+    ! -path '*/__MACOSX/*' \
+    -print0
+}
+
+find_plugin_files() {
+  local root="$1"
+  local suffix="$2"
+
+  find "${root}" \
+    -type f \
+    -name "*.${suffix}" \
+    ! -path '*/__MACOSX/*' \
+    -print0
+}
@@
