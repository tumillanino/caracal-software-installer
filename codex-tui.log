+#!/usr/bin/env python3
+from __future__ import annotations
+
+import argparse
+import csv
+import subprocess
+import sys
+from pathlib import Path
+
+
+SCRIPT_DIR = Path(__file__).resolve().parent
+DEFAULT_INDEX = SCRIPT_DIR.parent / "data" / "download-index.csv"
+KNOWN_FIELDS = {
+    "id",
+    "name",
+    "version",
+    "url",
+    "formats",
+    "primary_bundle_name",
+    "data_dir_name",
+    "data_target_name",
+    "warmplace_subdir",
+    "launcher_name",
+    "desktop_id",
+    "desktop_comment",
+    "repo_url",
+    "extract_dir",
+}
+REQUIRED_FIELDS = {"id", "name", "url"}
+
+
+def load_rows(index_path: Path) -> list[dict[str, str]]:
+    if not index_path.is_file():
+        raise SystemExit(f"Download index not found: {index_path}")
+
+    with index_path.open(newline="", encoding="utf-8") as handle:
+        reader = csv.DictReader(handle)
+        if reader.fieldnames is None:
+            raise SystemExit(f"Download index is missing a header row: {index_path}")
+        unknown = set(reader.fieldnames) - KNOWN_FIELDS
+        if unknown:
+            raise SystemExit(
+                f"Download index contains unknown columns: {', '.join(sorted(unknown))}"
+            )
+        missing = REQUIRED_FIELDS - set(reader.fieldnames)
+        if missing:
+            raise SystemExit(
+                f"Download index is missing required columns: {', '.join(sorted(missing))}"
+            )
+        return [{key: (value or "").strip() for key, value in row.items()} for row in reader]
+
+
+def rows_by_id(rows: list[dict[str, str]]) -> dict[str, dict[str, str]]:
+    lookup: dict[str, dict[str, str]] = {}
+    duplicates: set[str] = set()
+    for row in rows:
+        package_id = row["id"]
+        if not package_id:
+            raise SystemExit("Download index contains a row with an empty id.")
+        if package_id in lookup:
+            duplicates.add(package_id)
+        lookup[package_id] = row
+
+    if duplicates:
+        raise SystemExit(
+            f"Download index contains duplicate ids: {', '.join(sorted(duplicates))}"
+        )
+
+    return lookup
+
+
+def get_value(index_path: Path, package_id: str, field: str, allow_empty: bool) -> int:
+    if field not in KNOWN_FIELDS:
+        raise SystemExit(f"Unknown field: {field}")
+
+    lookup = rows_by_id(load_rows(index_path))
+    row = lookup.get(package_id)
+    if row is None:
+        raise SystemExit(f"Package id not found in download index: {package_id}")
+
+    value = row.get(field, "")
+    if not value and not allow_empty:
+        raise SystemExit(f"Field '{field}' is empty for package id '{package_id}'")
+
+    print(value)
+    return 0
+
+
+def validate(index_path: Path, check_urls: bool, timeout: int) -> int:
+    rows = load_rows(index_path)
+    lookup = rows_by_id(rows)
+
+    for package_id, row in sorted(lookup.items()):
+        for field in REQUIRED_FIELDS:
+            if not row.get(field):
+                print(f"[error] {package_id}: missing required field '{field}'", file=sys.stderr)
+                return 1
+
+    if not check_urls:
+        print(f"Validated {len(lookup)} download index entries.")
+        return 0
+
+    failures = 0
+    for package_id, row in sorted(lookup.items()):
+        url = row["url"]
+        print(f"[check] {package_id}: {url}")
+        head = subprocess.run(
+            [
+                "curl",
+                "-fsSIL",
+                "--retry",
+                "2",
+                "--retry-delay",
+                "2",
+                "--max-time",
+                str(timeout),
+                url,
+            ],
+            capture_output=True,
+            text=True,
+        )
+        if head.returncode == 0:
+            continue
+
+        get = subprocess.run(
+            [
+                "curl",
+                "-fsSL",
+                "--range",
+                "0-0",
+                "--retry",
+                "2",
+                "--retry-delay",
+                "2",
+                "--max-time",
+                str(timeout),
+                url,
+            ],
+            capture_output=True,
+            text=True,
+        )
+        if get.returncode == 0:
+            continue
+
+        failures += 1
+        print(f"[broken] {package_id}: {url}", file=sys.stderr)
+        stderr = (head.stderr or get.stderr).strip()
+        if stderr:
+            print(stderr, file=sys.stderr)
+
+    if failures:
+        print(f"Found {failures} broken link(s).", file=sys.stderr)
+        return 1
+
+    print(f"Validated {len(lookup)} download index entries and confirmed all URLs responded.")
+    return 0
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser(description="Read and validate the Caracal download index.")
+    parser.add_argument(
+        "--index",
+        default=str(DEFAULT_INDEX),
+        help="Path to the CSV download index.",
+    )
+
+    subparsers = parser.add_subparsers(dest="command", required=True)
+
+    get_parser = subparsers.add_parser("get", help="Read a required field from the index.")
+    get_parser.add_argument("package_id")
+    get_parser.add_argument("field")
+
+    get_optional_parser = subparsers.add_parser(
+        "get-optional",
+        help="Read a field from the index and allow empty values.",
+    )
+    get_optional_parser.add_argument("package_id")
+    get_optional_parser.add_argument("field")
+
+    validate_parser = subparsers.add_parser("validate", help="Validate the index file.")
+    validate_parser.add_argument(
+        "--check-urls",
+        action="store_true",
+        help="Use curl to confirm each download URL still responds.",
+    )
+    validate_parser.add_argument(
+        "--timeout",
+        type=int,
+        default=20,
+        help="Maximum time in seconds for each URL probe.",
+    )
+
+    args = parser.parse_args()
+    index_path = Path(args.index).resolve()
+
+    if args.command == "get":
+        return get_value(index_path, args.package_id, args.field, allow_empty=False)
+    if args.command == "get-optional":
+        return get_value(index_path, args.package_id, args.field, allow_empty=True)
+    if args.command == "validate":
+        return validate(index_path, args.check_urls, args.timeout)
+
+    raise SystemExit(f"Unsupported command: {args.command}")
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
