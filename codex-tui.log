*** Update File: /var/home/atumia/caracal-stuff-latest/tumillanino/caracal/system_files/shared/usr/libexec/caracal-user-setup
@@
 CARACAL_CONFIG_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/caracal"
 mkdir -p "$CARACAL_CONFIG_DIR"
-
-# Bump this when branding or default app changes need re-application across rebases.
-USER_SETUP_VER=9
-USER_SETUP_VER_FILE="$CARACAL_CONFIG_DIR/version"
-
-if [[ -f "$USER_SETUP_VER_FILE" ]]; then
-  STORED_VER=$(cat "$USER_SETUP_VER_FILE")
-  if [[ "$USER_SETUP_VER" == "$STORED_VER" ]]; then
-    echo "caracal-user-setup v$USER_SETUP_VER already ran. Exiting."
-    exit 0
-  fi
-fi
 
 WALLPAPER="/usr/share/wallpapers/caracal/caracal-lake.png"
 USER_SHELL="$(getent passwd "$(id -un)" | cut -d: -f7)"
 ALACRITTY_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/alacritty/alacritty.toml"
 USER_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}"
@@
 DESIRED_PANEL_LAUNCHERS_CSV="$(
   IFS=,
   printf '%s' "${DESIRED_PANEL_LAUNCHERS[*]}"
 )"
+
+sync_live_panel_launchers() {
+  if ! command -v qdbus6 &>/dev/null; then
+    return
+  fi
+
+  qdbus6 org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript '
+    const desiredLaunchers = [
+      "applications:Alacritty.desktop",
+      "applications:io.github.kolunmi.Bazaar.desktop",
+      "applications:app.zen_browser.zen.desktop",
+      "applications:ardour9.desktop"
+    ];
+
+    for (const panel of panels()) {
+      for (const widget of panel.widgets()) {
+        if (widget.type !== "org.kde.plasma.icontasks") {
+          continue;
+        }
+
+        widget.currentConfigGroup = ["General"];
+        const currentLaunchers = widget.readConfig("launchers", "");
+        if (!currentLaunchers || currentLaunchers.trim() === "") {
+          widget.writeConfig("launchers", desiredLaunchers);
+          widget.reloadConfig();
+        }
+      }
+    }
+  ' 2>/dev/null || true
+}
 
 DESIRED_KICKOFF_FAVORITES=(
@@
 DESIRED_KICKOFF_FAVORITES_CSV="$(
   IFS=,
   printf '%s' "${DESIRED_KICKOFF_FAVORITES[*]}"
 )"
+
+# Keep the live panel seeded on every session. Plasma can write the user's
+# panel config after the first-run pass, so this cannot be version-gated.
+sync_live_panel_launchers
+
+# Bump this when branding or default app changes need re-application across rebases.
+USER_SETUP_VER=10
+USER_SETUP_VER_FILE="$CARACAL_CONFIG_DIR/version"
+
+if [[ -f "$USER_SETUP_VER_FILE" ]]; then
+  STORED_VER=$(cat "$USER_SETUP_VER_FILE")
+  if [[ "$USER_SETUP_VER" == "$STORED_VER" ]]; then
+    echo "caracal-user-setup v$USER_SETUP_VER already ran."
+    exit 0
+  fi
+fi
@@
-# Converge the panel pins on Caracal defaults without resetting the rest
-# of the user's panel layout.
-PLASMA_APPLETSRC="$USER_CONFIG_DIR/plasma-org.kde.plasma.desktop-appletsrc"
-if [[ -f "$PLASMA_APPLETSRC" ]]; then
-  # Rebases from Kinoite already have a panel config, so update the persisted
-  # launcher list directly instead of relying only on a live Plasma script.
-  perl -0pi -e 's/^launchers=.*$/launchers=$ENV{DESIRED_PANEL_LAUNCHERS_CSV}/mg' "$PLASMA_APPLETSRC"
-fi
-
-if command -v qdbus6 &>/dev/null; then
-  qdbus6 org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript '
-    const desiredLaunchers = [
-      "applications:Alacritty.desktop",
-      "applications:io.github.kolunmi.Bazaar.desktop",
-      "applications:app.zen_browser.zen.desktop",
-      "applications:ardour9.desktop"
-    ];
-
-    for (const panel of panels()) {
-      for (const widget of panel.widgets()) {
-        if (widget.type === "org.kde.plasma.icontasks") {
-          widget.currentConfigGroup = ["General"];
-          widget.writeConfig("launchers", desiredLaunchers);
-          widget.reloadConfig();
-        }
-      }
-    }
-  ' 2>/dev/null || true
-fi
-
 # Seed the Kickoff favorites menu with standalone studio tools so apps that do
 # not surface as DAW plugins remain easy to discover.
 update_kickoff_favorites_file "$USER_CONFIG_DIR/kactivitymanagerd-statsrc"
