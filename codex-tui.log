*** Update File: /var/home/atumia/caracal-stuff-latest/tumillanino/caracal/system_files/shared/usr/libexec/caracal-user-setup
@@
 CARACAL_CONFIG_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/caracal"
 mkdir -p "$CARACAL_CONFIG_DIR"
+USER_SETUP_VER_FILE="$CARACAL_CONFIG_DIR/version"
+FIRST_CARACAL_RUN=0
+if [[ ! -f "$USER_SETUP_VER_FILE" ]]; then
+  FIRST_CARACAL_RUN=1
+fi
 
 WALLPAPER="/usr/share/wallpapers/caracal/caracal-lake.png"
 USER_SHELL="$(getent passwd "$(id -un)" | cut -d: -f7)"
 ALACRITTY_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/alacritty/alacritty.toml"
 USER_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}"
@@
-sync_live_panel_launchers() {
+sync_live_panel_launchers() {
+  local force="${1:-0}"
+
   if ! command -v qdbus6 &>/dev/null; then
     return
   fi
 
   qdbus6 org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript '
@@
         }
 
         widget.currentConfigGroup = ["General"];
         const currentLaunchers = widget.readConfig("launchers", "");
-        if (!currentLaunchers || currentLaunchers.trim() === "") {
+        const shouldForce = '"${force}"' === "1";
+        if (shouldForce || !currentLaunchers || currentLaunchers.trim() === "") {
           widget.writeConfig("launchers", desiredLaunchers);
           widget.reloadConfig();
         }
       }
     }
@@
-# Keep the live panel seeded on every session. Plasma can write the user's
-# panel config after the first-run pass, so this cannot be version-gated.
-sync_live_panel_launchers
+# Keep the live panel seeded on every session. On the first Caracal run after
+# a rebase from another image, force the Caracal pins once. After that, only
+# repair an empty taskbar so user customization is preserved.
+sync_live_panel_launchers "$FIRST_CARACAL_RUN"
 
 # Bump this when branding or default app changes need re-application across rebases.
 USER_SETUP_VER=10
-USER_SETUP_VER_FILE="$CARACAL_CONFIG_DIR/version"
 
 if [[ -f "$USER_SETUP_VER_FILE" ]]; then
   STORED_VER=$(cat "$USER_SETUP_VER_FILE")
