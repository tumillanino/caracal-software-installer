*** Update File: /var/home/atumia/caracal-stuff-latest/tumillanino/caracal/system_files/shared/usr/share/applications/caracal-software-installer.desktop
@@
 Exec=caracal-software-installer
 TryExec=caracal-software-installer
-Icon=caracal-logo-icon
+Icon=/usr/share/icons/hicolor/scalable/places/app-icon-dark.svg
 Terminal=true
 StartupNotify=true
 Categories=AudioVideo;Audio;System;
 Keywords=caracal;audio;installer;plugins;daw;
*** Update File: /var/home/atumia/caracal-stuff-latest/tumillanino/caracal/system_files/shared/usr/libexec/caracal-user-setup
@@
-USER_SETUP_VER=8
+USER_SETUP_VER=9
 USER_SETUP_VER_FILE="$CARACAL_CONFIG_DIR/version"
@@
 USER_SHELL="$(getent passwd "$(id -un)" | cut -d: -f7)"
 ALACRITTY_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/alacritty/alacritty.toml"
 USER_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}"
+SOFTWARE_INSTALLER_DESKTOP_SOURCE="/usr/share/applications/caracal-software-installer.desktop"
 
 mkdir -p "$USER_CONFIG_DIR"
@@
 # -- Desktop wallpaper --
 if command -v plasma-apply-wallpaperimage &>/dev/null; then
   plasma-apply-wallpaperimage "$WALLPAPER" || true
 fi
+
+# -- Desktop shortcuts --
+DESKTOP_DIR="$(xdg-user-dir DESKTOP 2>/dev/null || true)"
+if [[ -z "$DESKTOP_DIR" ]]; then
+  DESKTOP_DIR="$HOME/Desktop"
+fi
+
+if [[ -f "$SOFTWARE_INSTALLER_DESKTOP_SOURCE" ]]; then
+  install -d "$DESKTOP_DIR"
+  install -m755 "$SOFTWARE_INSTALLER_DESKTOP_SOURCE" \
+    "$DESKTOP_DIR/caracal-software-installer.desktop"
+fi
 
 # -- Alacritty migration --
 if [[ -n "$USER_SHELL" ]] && [[ -f "$ALACRITTY_CONFIG" ]]; then
