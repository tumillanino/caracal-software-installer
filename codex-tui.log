+PREFIX ?= /usr
+BINDIR ?= $(PREFIX)/bin
+LIBDIR ?= $(PREFIX)/lib
+LIBEXECDIR ?= $(PREFIX)/libexec
+SHAREDIR ?= $(PREFIX)/share
+
+INSTALLER_NAME := caracal-software-installer
+INDEX_NAME := caracal-download-index
+BUILD_DIR := bin
+SCRIPT_DIR := scripts
+DATA_DIR := data
+ASSET_DIR := assets
+
+INSTALLER_BIN := $(BUILD_DIR)/$(INSTALLER_NAME)
+INDEX_BIN := $(BUILD_DIR)/$(INDEX_NAME)
+
+INSTALL_SCRIPT_DIR := $(LIBDIR)/caracal-software-installer/scripts
+INSTALL_DATA_DIR := $(LIBDIR)/caracal-software-installer/data
+INSTALL_LIBEXEC_DIR := $(LIBEXECDIR)/caracal-software-installer
+INSTALL_SHARE_DIR := $(SHAREDIR)/caracal-software-installer
+
+.PHONY: all build build-installer build-index test validate clean install install-binaries install-data install-assets install-logo install-scripts
+
+all: build
+
+build: build-installer build-index
+
+build-installer: $(INSTALLER_BIN)
+
+build-index: $(INDEX_BIN)
+
+$(INSTALLER_BIN):
+	mkdir -p $(BUILD_DIR)
+	go build -o $(INSTALLER_BIN) ./cmd/caracal-software-installer
+
+$(INDEX_BIN):
+	mkdir -p $(BUILD_DIR)
+	go build -o $(INDEX_BIN) ./cmd/caracal-download-index
+
+test:
+	go test ./...
+
+validate: build-index
+	CARACAL_INSTALLER_DOWNLOAD_INDEX_BIN="$(CURDIR)/$(INDEX_BIN)" $(CURDIR)/scripts/download-index validate
+
+clean:
+	rm -rf $(BUILD_DIR)
+
+install: build install-binaries install-data install-assets install-logo install-scripts
+
+install-binaries:
+	install -Dm755 $(INSTALLER_BIN) $(DESTDIR)$(BINDIR)/$(INSTALLER_NAME)
+	install -Dm755 $(INDEX_BIN) $(DESTDIR)$(INSTALL_LIBEXEC_DIR)/$(INDEX_NAME)
+
+install-data:
+	install -Dm644 $(DATA_DIR)/download-index.csv $(DESTDIR)$(INSTALL_DATA_DIR)/download-index.csv
+
+install-assets:
+	install -Dm644 $(ASSET_DIR)/images/reaper.png $(DESTDIR)$(INSTALL_SHARE_DIR)/assets/images/reaper.png
+
+install-logo:
+	install -Dm644 logo.txt $(DESTDIR)$(INSTALL_SHARE_DIR)/logo.txt
+
+install-scripts:
+	mkdir -p $(DESTDIR)$(INSTALL_SCRIPT_DIR)
+	cp $(SCRIPT_DIR)/* $(DESTDIR)$(INSTALL_SCRIPT_DIR)/
+	chmod 755 $(DESTDIR)$(INSTALL_SCRIPT_DIR)/*
