+func candidateRelativePaths(start string, relative string) []string {
+	var paths []string
+	for dir := filepath.Clean(start); ; dir = filepath.Dir(dir) {
+		paths = append(paths, filepath.Join(dir, relative))
+		parent := filepath.Dir(dir)
+		if parent == dir {
+			break
+		}
+	}
+	return paths
+}
